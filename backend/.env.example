# Anthropic API Key
ANTHROPIC_API_KEY=your-api-key-here

# Database Configuration
# 
# For LOCAL DEVELOPMENT - SQLite (default):
# DATABASE_URL=sqlite:///./modduel.db
#
# For PRODUCTION ON VERCEL - Use PostgreSQL:
# 
# Option 1 - Neon (RECOMMENDED):
#   1. Go to https://console.neon.tech
#   2. Sign up with GitHub  
#   3. Create a project and database
#   4. Copy "Pooled connection" string
#   5. Paste below:
# DATABASE_URL=postgresql://user:password@host/dbname
#
# Option 2 - Supabase:
#   1. Go to https://supabase.com
#   2. Create a project
#   3. Settings > Database > Connection string (Pooled)
#   4. Paste below:
# DATABASE_URL=postgresql://user:password@host/dbname
#
# Option 3 - Railway:
#   1. Go to https://railway.app
#   2. Add PostgreSQL plugin
#   3. Copy generated DATABASE_URL
#
# ⚠️  IMPORTANT: SQLite will NOT work on Vercel's ephemeral filesystem

DATABASE_URL=sqlite:///./modduel.db
